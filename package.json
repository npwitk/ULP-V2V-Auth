{
  "name": "ulp-v2v-auth",
  "version": "1.0.0",
  "description": "ULP-V2V-Auth: Ultra-Low-Latency Privacy-Preserving V2V Authentication using Groth16 zk-SNARKs",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "gen-input": "node scripts/gen_input.js",
    "prove": "node scripts/prove_and_verify.js",
    "bench": "node benchmark/bench_prover.js",
    "bench-batch": "node benchmark/bench_batch_verify.js",
    "bench-pairing": "node benchmark/bench_pairing_breakdown.js",
    "bench-poseidon": "node benchmark/bench_poseidon.js",
    "bench-rapid": "node benchmark/bench_rapidsnark.js",
    "bench-ecdsa": "node benchmark/bench_ecdsa_baseline.js",
    "bench-cache": "node benchmark/bench_proof_cache.js",
    "bench-primitives": "node benchmark/bench_primitives.js",
    "bench-dcv": "node benchmark/bench_dcv.js",
    "bench-raba": "node benchmark/bench_raba.js",
    "bench-ablation": "node benchmark/bench_raba_ablation.js",
    "bench-comparison": "node benchmark/bench_comparison.js",
    "bench-e2e": "node obu/bench_e2e.js",
    "ta-server": "node server/ta_server.js",
    "ais-server": "node server/ais_server.js --ta=http://127.0.0.1:3001",
    "register": "node obu/register.js",
    "acquire": "node obu/acquire_ast.js",
    "install-rapidsnark": "bash scripts/install_rapidsnark.sh",
    "plot": "python3 benchmark/plot_results.py",
    "demo": "node demo/server.js"
  },
  "dependencies": {
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "express": "^4.22.1",
    "ffjavascript": "^0.3.0",
    "snarkjs": "^0.7.4",
    "ws": "^8.19.0"
  }
}
